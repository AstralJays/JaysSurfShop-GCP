# Local Compose defaults to OpenAI. On GKE/Cloud Run, Terraform sets LLM_PROVIDER=vertex.
OPENAI_API_KEY=sk-your-key-here

# Optional: use Vertex locally (needs ADC + project with Vertex AI enabled)
# LLM_PROVIDER=vertex
# IMAGE_PROVIDER=vertex
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GCP_REGION=us-central1
# AI_MODEL_CHAT=gemini-2.0-flash-001
# AI_MODEL_EMBED=text-embedding-004
# AI_MODEL=imagen-3.0-generate-001

# Service URLs (defaults work with docker-compose)
CHAT_SERVICE_URL=http://localhost:8001
BOARD_SERVICE_URL=http://localhost:8002
NEXT_PUBLIC_CHAT_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_BOARD_SERVICE_URL=http://localhost:8002

# Deployment metadata
ENVIRONMENT=local
DEPLOYMENT_ID=local
SERVICE_NAME=frontend
LOG_FORMAT=json
NEXT_PUBLIC_APP_ENV=local

# TF_VAR_openai_api_key=sk-...   # optional when llm_provider/image_provider = vertex
