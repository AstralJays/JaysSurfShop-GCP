project_id   = "your-gcp-project-id"
region       = "us-central1"
project_name = "jays-surf-shop"
environment  = "demo"

# Defaults: Vertex Gemini + Imagen (no OpenAI required)
# llm_provider   = "vertex"
# image_provider = "vertex"
# openai_api_key = "sk-..."   # only if llm_provider/image_provider = "openai"

# github_deploy_repo = "AstralJays/JaysSurfShop-GCP"

# upwind_client_id     = "..."
# upwind_client_secret = "..."
# GKE only: enables Upwind sensor (node scan agents) + Admission Controller webhook.
# Cloud Run tracer uses the same credentials but is configured separately — see cloud-run/README.md.
