project_id   = "your-gcp-project-id"
region       = "us-central1"
project_name = "jays-surf-shop"
environment  = "demo"

# Restrict frontend LB + VPC HTTP (default is world-open for workshops)
# allowed_cidr_blocks = ["203.0.113.10/32"]

# Defaults: Vertex Gemini for chat; OpenAI for board images (Imagen optional if enabled)
# llm_provider   = "vertex"
# image_provider = "openai"
# openai_api_key = "sk-..."   # required for board-generator when image_provider = openai

# github_deploy_repo = "AstralJays/JaysSurfShop-GCP"

# upwind_client_id     = "..."
# upwind_client_secret = "..."
# GKE only: enables Upwind sensor (node scan agents) + Admission Controller webhook.
# Cloud Run tracer uses the same credentials but is configured separately — see cloud-run/README.md.
